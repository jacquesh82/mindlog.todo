# ---------------------------------------------------------------------------
# mindlog.todo — example environment. Copy to `.env` and adjust.
# Defaults work out-of-the-box with `docker compose up` (local embeddings,
# no external API keys required).
# ---------------------------------------------------------------------------

# --- Server ---
PORT=8080
# Public base URL the app is served from. With docker compose the web edge
# terminates TLS and proxies the API, so everything is same-origin under this host.
PUBLIC_URL=https://todo.mindlog.localhost
# Web app base URL (Google OAuth redirects back here after sign-in).
WEB_URL=https://todo.mindlog.localhost

# --- Database ---
# Inside docker-compose the host is the `db` service. For local runs use localhost.
DATABASE_URL=postgres://mindlog:mindlog@db:5432/mindlog

# --- Embeddings (RAG) ---
# Provider: local | voyage | openai
EMBEDDING_PROVIDER=local
# Vector dimension MUST match the provider (local/MiniLM=384, voyage-3=1024,
# openai text-embedding-3-small=1536). Changing it requires re-embedding.
EMBEDDING_DIM=384
# Required only for the matching provider:
VOYAGE_API_KEY=
OPENAI_API_KEY=

# --- Generative "ask" tool ---
# Set a chat key here to run in CLOUD-HOSTED mode: a shared key is used and each
# user's monthly token usage is metered + capped (AI_MONTHLY_TOKEN_LIMIT).
# Leave it empty for SELF-HOSTED / BYOK mode: each user sets their own model +
# key in Settings → AI (their key is encrypted with ENCRYPTION_KEY).
ANTHROPIC_API_KEY=
ASK_MODEL=claude-sonnet-4-6
# Optional explicit chat config (fall back to ANTHROPIC_API_KEY / ASK_MODEL):
AI_CHAT_API_KEY=
AI_CHAT_MODEL=claude-sonnet-4-6
# Per-user monthly token budget enforced in cloud-hosted mode.
AI_MONTHLY_TOKEN_LIMIT=1000000

# --- Auth ---
# CHANGE THIS in any non-local deployment (use a long random string).
JWT_SECRET=dev-only-change-me
# Master key for encrypting per-user secrets at rest (their own LLM API key).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=dev-only-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Google OAuth (optional; leave empty to disable the Google button) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://todo.mindlog.localhost/api/v1/auth/google/callback

# --- mindlog id (central OIDC provider — "Sign in with mindlog id") ---
# Values must match the first-party client seeded in mindlog.id (the MINDLOG_TODO_*
# vars in mindlog.id/.env). Generate the secret with: openssl rand -hex 32.
# Leave CLIENT_ID/SECRET empty to disable the button (route returns 503 otherwise).
# In dev the api container reaches https://id.mindlog.localhost via the host
# gateway and trusts the mkcert root CA — see docker-compose.yml.
MINDLOG_ID_ISSUER=https://id.mindlog.localhost
MINDLOG_ID_CLIENT_ID=mindlog-todo-dev
MINDLOG_ID_CLIENT_SECRET=
MINDLOG_ID_REDIRECT_URI=https://todo.mindlog.localhost/api/v1/auth/mindlog-id/callback

# --- Web (Vite, build-time) ---
# Empty => the SPA calls same-origin /api (proxied by the web edge). For local
# `npm run dev:web` (Vite on :5173) leave empty too; the dev proxy handles /api.
VITE_API_URL=
