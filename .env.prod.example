# ---------------------------------------------------------------------------
# mindlog.todo — PRODUCTION environment for str01. Copy to `.env` on the server
# (in the deploy dir) and fill in real secrets. NEVER commit the real .env.
#
# Used by docker-compose.prod.yml. The CI deploy never overwrites this file —
# it lives only on the server.
# ---------------------------------------------------------------------------

# --- Public URLs (the externally visible https origin, incl. the /app sub-path) ---
# The app is served under /app; the root is the marketing site (mindlog.todo.web).
PUBLIC_URL=https://todo.mindlog.today/app
WEB_URL=https://todo.mindlog.today/app

# --- Server ---
PORT=8080

# --- Database (internal to the compose network; db port is NOT published) ---
POSTGRES_USER=mindlog
# CHANGE THIS — use a long random password.
POSTGRES_PASSWORD=change-me-strong-random
POSTGRES_DB=mindlog

# --- Web binding (loopback HTTP port the Astro front proxies /app to) ---
# The web container serves plain HTTP; the front (mindlog.todo.web) terminates
# TLS for todo.mindlog.today and proxies /app here. Defaults: 127.0.0.1:8080.
WEB_HTTP_BIND=127.0.0.1
WEB_HTTP_PORT=8080

# --- Embeddings (RAG) ---
EMBEDDING_PROVIDER=local
EMBEDDING_DIM=384
VOYAGE_API_KEY=
OPENAI_API_KEY=

# --- Generative "ask" tool ---
ANTHROPIC_API_KEY=
ASK_MODEL=claude-sonnet-4-6

# --- Auth ---
# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Google OAuth (optional; leave empty to disable the Google button) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://todo.mindlog.today/app/api/v1/auth/google/callback

# --- mindlog id (central OIDC provider — "Sign in with mindlog id") ---
# CLIENT_ID/SECRET must match the first-party client seeded in mindlog.id on the
# server (the MINDLOG_TODO_* vars in id.mindlog.today's .env). The REDIRECT_URI
# must be listed EXACTLY in MINDLOG_TODO_REDIRECT_URIS there. Generate the secret
# with: openssl rand -hex 32. Issuer is the real public HTTPS origin (no CA setup
# needed in prod). Leave CLIENT_ID/SECRET empty to disable the button.
MINDLOG_ID_ISSUER=https://id.mindlog.today
MINDLOG_ID_CLIENT_ID=mindlog-todo-prod
MINDLOG_ID_CLIENT_SECRET=change-me-openssl-rand-hex-32
MINDLOG_ID_REDIRECT_URI=https://todo.mindlog.today/app/api/v1/auth/mindlog-id/callback

# --- Web (build-time, baked into the image by CI; not read at runtime) ---
# CI builds the SPA with VITE_API_URL=/app and VITE_BASE=/app/ so it lives under
# the /app sub-path. Listed here for reference only.
VITE_API_URL=/app
