# ---------------------------------------------------------------------------
# mindlog.todo — PRODUCTION environment for str01. Copy to `.env` on the server
# (in the deploy dir) and fill in real secrets. NEVER commit the real .env.
#
# Used by docker-compose.prod.yml. The CI deploy never overwrites this file —
# it lives only on the server.
# ---------------------------------------------------------------------------

# --- Public URLs (the externally visible https origin served by your proxy) ---
# The real domain str01's reverse proxy exposes for the app.
PUBLIC_URL=https://todo.mindlog.today
WEB_URL=https://todo.mindlog.today

# --- Server ---
PORT=8080

# --- Database (internal to the compose network; db port is NOT published) ---
POSTGRES_USER=mindlog
# CHANGE THIS — use a long random password.
POSTGRES_PASSWORD=change-me-strong-random
POSTGRES_DB=mindlog

# --- Edge binding (loopback HTTPS port the SNI-passthrough edge routes to) ---
# This container terminates TLS itself; the host edge demuxes by SNI to here.
# Defaults: bind 127.0.0.1:9743 -> container :443. The Let's Encrypt cert for
# the domain below must already exist under /etc/letsencrypt (mounted ro).
WEB_HTTPS_BIND=127.0.0.1
WEB_HTTPS_PORT=9743

# --- Embeddings (RAG) ---
EMBEDDING_PROVIDER=local
EMBEDDING_DIM=384
VOYAGE_API_KEY=
OPENAI_API_KEY=

# --- Generative "ask" tool ---
ANTHROPIC_API_KEY=
ASK_MODEL=claude-sonnet-4-6

# --- Auth ---
# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Google OAuth (optional; leave empty to disable the Google button) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://todo.mindlog.today/api/v1/auth/google/callback

# --- Web (build-time, baked into the image in CI; keep empty for same-origin) ---
VITE_API_URL=
